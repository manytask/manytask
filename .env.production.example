# --- GitLab (dev GitLab for EDUCATION-59068) ---
BOT_GITLAB_TOKEN=<api-scope token of service user @manytask-mr-reviewer-bot>
# Both names resolve (alias + prefixed field name). MUST be set or it defaults to gitlab.com.
GITLAB_BASE_URL=https://gitlab.manytask2.org
BOT_GITLAB_BASE_URL=https://gitlab.manytask2.org

# --- Bot admin API auth for /courses ---
BOT_ADMIN_TOKEN=<random 32 bytes, e.g. `openssl rand -hex 32`>

# --- Redis (in-stack) ---
REDIS_URL=redis://mrr-redis:6379/0

# --- manytask2 ---
MANYTASK_BASE_URL=https://manytask2.org

# --- Bot identity on GitLab (config reads BOT_USERNAME; set both) ---
BOT_USERNAME=manytask-mr-reviewer-bot
BOT_BOT_USERNAME=manytask-mr-reviewer-bot

# --- Stand tuning (decision D4) ---
POLL_INTERVAL_SEC=120
HEALTHZ_POLL_STALE_SEC=600
LOG_JSON=false
LOG_LEVEL=INFO
