# GitLab access
BOT_GITLAB_TOKEN=changeme

# Admin API auth for /courses
BOT_ADMIN_TOKEN=changeme

# Redis connection used by the bot
REDIS_URL=redis://redis:6379/0

# Manytask service base URL (mock in dev)
MANYTASK_BASE_URL=http://mock-manytask:8080

# Worker poll interval in seconds
POLL_INTERVAL_SEC=900

# Hard per-MR processing timeout inside the poll cycle (seconds)
PER_MR_TIMEOUT_SEC=120

# Per-request timeout for manytask HTTP calls (seconds)
BOT_MANYTASK_REQUEST_TIMEOUT_SEC=5.0

# How long to cache a successful course-token validation (seconds)
BOT_PING_CACHE_TTL_SEC=30

# GitLab API base URL (no trailing slash)
BOT_GITLAB_BASE_URL=https://gitlab.com

# Worker threads for sync python-gitlab calls
BOT_HOSTING_EXECUTOR_WORKERS=32

# GitLab username under which the bot posts comments. Used to filter anchored
# comments — only comments authored by this user can be updated; comments
# faked by a student with the same anchor are ignored.
BOT_BOT_USERNAME=manytask-mr-reviewer-bot

# Hard timeout (seconds) for a single run: checklist step.
BOT_RUN_STEP_TIMEOUT_SEC=60

# Label always applied after a successful checklist run.
BOT_BOT_LABEL_PROCESSED=checklist

# Label additionally applied when at least one step failed.
BOT_BOT_LABEL_FAIL=fix it

# --- Observability ---
# Default loguru level for all modules
LOG_LEVEL=INFO
# Emit logs as JSON on stdout (set false for human-readable local dev)
LOG_JSON=true
# Per-module level overrides, comma-separated (module=LEVEL,module2=LEVEL)
LOG_MODULE_LEVELS=
# /healthz returns 503 if the last poll cycle finished more than this many seconds ago
HEALTHZ_POLL_STALE_SEC=1800

# --- Reliability ---
# Manytask retry (1 = no retry)
MANYTASK_RETRY_ATTEMPTS=3
MANYTASK_RETRY_BACKOFF_SEC=0.5
MANYTASK_RETRY_MAX_BACKOFF_SEC=5.0
# GitLab retry (1 = no retry)
GITLAB_RETRY_ATTEMPTS=3
GITLAB_RETRY_BACKOFF_SEC=0.5
GITLAB_RETRY_MAX_BACKOFF_SEC=10.0
# GitLab rate-limit throttling: sleep when RateLimit-Remaining / RateLimit-Limit < threshold
GITLAB_RATE_LIMIT_THRESHOLD=0.1
GITLAB_RATE_LIMIT_MAX_SLEEP_SEC=60.0
GITLAB_RATE_LIMIT_FALLBACK_SLEEP_SEC=5.0
